# Database
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rohitpedia

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# LLM
GEMINI_API_KEY=
LLM_ABSORB_PROVIDER=gemini
LLM_ABSORB_MODEL=gemini-2.5-flash
LLM_FACETS_PROVIDER=openai_compat
LLM_FACETS_MODEL=llama-3.1-8b-instant
LLM_FACETS_FALLBACK_PROVIDER=ollama
LLM_FACETS_FALLBACK_MODEL=qwen3.5:4b
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_TIMEOUT_SECONDS=180

# Embeddings
EMBED_PROVIDER=ollama
EMBED_MODEL=nomic-embed-text
OLLAMA_HOST=http://localhost:11434

# App
WEBAPP_URL=http://localhost:3000
MEDIA_STORAGE=local
MEDIA_DIR=./media
TESSERACT_BIN=C:/Program Files/Tesseract-OCR/tesseract.exe

# Optional (Docling/Hugging Face download performance)
HF_TOKEN=
HF_HUB_DISABLE_SYMLINKS_WARNING=1
